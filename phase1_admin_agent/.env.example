# Copy to .env and adjust. All values have sensible defaults.

# --- Operating mode -------------------------------------------------------
# Set to 1/true to run with no AWS calls (heuristic extraction + summary).
ADMIN_AGENT_MOCK=0

# --- AWS / Bedrock --------------------------------------------------------
AWS_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Action register ------------------------------------------------------
# Backend: sqlite (local) or dynamodb (AWS)
ACTION_REGISTRY_BACKEND=sqlite
ACTION_REGISTRY_SQLITE_PATH=action_register.db
ACTION_REGISTRY_TABLE=ctt-action-register

# --- Output ---------------------------------------------------------------
# Local directory, or an s3://bucket/prefix URI to upload artifacts.
ADMIN_AGENT_OUTPUT=output

# --- Amazon Transcribe (only for audio/video recordings) ------------------
TRANSCRIBE_OUTPUT_BUCKET=
